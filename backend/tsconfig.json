{
    "compilerOptions": {
        "target": "ES2021",
        "module": "commonjs",
        "rootDir": "src",
        "outDir": "dist",
        "strict": true,
        "strictNullChecks": true,
        "esModuleInterop": true,
        "incremental": true,
        "skipLibCheck": true
    },
    "include": [
        "src",
        "src/types/**/*.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "test"
    ]
}